rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper function
    function isAuthenticated() {
      return request.auth != null;
    }

    // Chat Media (Images, Videos, Docs)
    match /chats/{roomId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.resource.size < 50 * 1024 * 1024; // 50MB max
    }

    // Community Post Media (Photos, Docs, Audio, Video)
    match /community/{roomId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.resource.size < 100 * 1024 * 1024; // 100MB max
    }

    // Evidence for Reports
    match /evidence/{userId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId && request.resource.size < 50 * 1024 * 1024;
    }
    
    // User Profile Media
    match /users/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
